{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities",
  "windows": ["main", "view-settings", "add-alarm", "view-edit-alarm", "view-chat-assistant", "alarm-firing"],
  "permissions": [
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://www.marqed.it/*" },
        { "url": "https://www.github.com.Marqed4/*" },
        { "url": "https://www.marqed4.github.io/*" },
        { "url": "https://www.marqed.it/CustomCalendar*" }
      ]
    },
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:window:allow-center",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}